export PATH="$PATH:/home/pm/.local/bin"

if [ "$TERM_PROGRAM" == "linux" ]; then
	setfont -d
	THEME="onehalf.minimal"
else
	THEME="~/.config.omp.toml"
fi

eval "$(oh-my-posh init bash -c $THEME)"

fastfetch
